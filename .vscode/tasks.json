{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure",
            "type": "shell",
            "command": "cmake -DCPPTEST_COVERAGE=ON -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -S . -B .build",
            "group": "build"
        },
        {
            "label": "Build and Run",
            "type": "shell",
            "command": "bash -c 'cmake --build .build && cd .build && rm -rf cpptest-coverage/CovGoogleTest/CovGoogleTest.clog && ctest || true && make cpptestcov-compute cpptestcov-suppress cpptestcov-report cpptestcov-dtp'",
            "group": "build"
        },
        {
            "label": "Update Coverage",
            "type": "shell",
            "command": "bash -c 'cd .build;make cpptestcov-suppress cpptestcov-report'",
            "group": "build"
        },
        {
            "label": "Publish coverage and test result to DTP",
            "type": "shell",
            "command": "bash -c 'cd .build;make cpptestcov-dtp'",
            "group": "build"
        },
        {
            "type": "cmake",
            "label": "CMake: configure",
            "command": "configure",
            "problemMatcher": [],
            "detail": "CMake template configure task"
        }
    ]
}